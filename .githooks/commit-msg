#!/usr/bin/env python3
"""Git commit-msg hook to enforce Conventional Commits format."""
import re
import sys

ALLOWED_TYPES = ["feat", "fix", "refactor", "build", "chore", "docs", "test"]
PATTERN = rf"^({'|'.join(ALLOWED_TYPES)})(\(.+\))?: .{{1,100}}$"

def main():
    commit_msg_file = sys.argv[1]
    with open(commit_msg_file, encoding="utf-8") as f:
        commit_msg = f.read().strip()

    if not re.match(PATTERN, commit_msg):
        print("ERROR: Invalid commit message format.")
        print()
        print("Expected format: type(scope): description")
        print(f"Allowed types: {', '.join(ALLOWED_TYPES)}")
        print()
        print("Examples:")
        print("  feat(router): add intent classification")
        print("  fix(refund): correct eligibility check")
        print("  docs: update API documentation")
        print()
        print("Rules:")
        print("  - All commit messages MUST be in English")
        print("  - Subject max 100 characters")
        print("  - No period at the end")
        sys.exit(1)

if __name__ == "__main__":
    main()
